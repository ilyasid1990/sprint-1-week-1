# ==========================================
# Менеджеры пакетов (pnpm, npm, yarn)
# ==========================================
node_modules/
.pnpm-store/

# Логи ошибок для всех менеджеров пакетов
*.log
*-debug.log*
*-error.log*
.npm/

# Кэш yarn v2/v3 (Zero-installs исключаются по умолчанию для безопасности)
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# ==========================================
# Сборка и компиляция (TypeScript)
# ==========================================
dist/
build/
out/
.tsbuildinfo

# Кэш линтеров и сборщиков
.eslintcache
.stylelintcache
.turbo/
.parcel-cache/

# ==========================================
# Настройки WebStorm (JetBrains IDE)
# ==========================================
.idea/

# ==========================================
# Конфиденциальные данные (Переменные окружения)
# ==========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key

# ==========================================
# Системные файлы ОС
# ==========================================
.DS_Store
Thumbs.db

# ==========================================
# Тестирование и покрытие кода
# ==========================================
coverage/
.nyc_output/
